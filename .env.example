# Bu faylı uniconnect/.env adı ilə kopyalayın (package.json ilə eyni qovluqda).
# Dəyərlərin ətrafında dırnaq qoymayın. Dəyişdikdən sonra npm run dev yenidən işə salın.

VITE_FIREBASE_API_KEY=your_api_key
# Boş buraxılsa projectId ilə təxmin edilir; Firebase Console çox vaxt .firebasestorage.app verir — eynisini yazın.
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123:web:abc

# Vergüllə ayırın; bu e-poçtlar tətbiqdə "Admin" panelinə giriş görür (parol burada yazılmır).
VITE_ADMIN_EMAILS=admin@unec.edu.az